{
  "name": "react-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "api": "php -S localhost:8088 -t public/api",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint \"app/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"app/**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --write \"app/**/*.{js,jsx,ts,tsx,css,md}\"",
    "format:fix": "lint-staged",
    "deps": "npx npm-check --skip-unused -u",
    "update-deps": "npx npm-check-updates -u",
    "prepare": "husky",
    "local": "concurrently --names \"FRONTEND,API\" --prefix-colors \"blue,green\" \"npm run dev\" \"npm run api\""
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@react-router/node": "^7.7.0",
    "@react-router/serve": "^7.13.1",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "isbot": "^5.1.35",
    "motion": "^12.35.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^9.16.0",
    "react-router": "^7.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@types/gtag.js": "^0.0.20",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "concurrently": "^9.2.1",
    "dompurify": "^3.3.2",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
